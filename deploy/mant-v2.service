[Unit]
Description=Mantenimientos Preventivos v2 (FastAPI / Uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mant
Group=mant
WorkingDirectory=/opt/mant_v2/web
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/mant_v2/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --proxy-headers --forwarded-allow-ips=*
Restart=always
RestartSec=5

# Límites razonables en LXC (ajusta si hace falta)
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
